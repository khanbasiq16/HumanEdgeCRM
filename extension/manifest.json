{
  "manifest_version": 3,
  "name": "HumanEdge Monitor",
  "version": "1.0.1",
  "description": "Silent screen monitoring for HumanEdge HR system",

  "permissions": [
    "tabs",
    "windows",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "128": "icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "HumanEdge Monitor",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "128": "icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
